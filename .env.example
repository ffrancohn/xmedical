SECRET_KEY=change-me-generate-a-secure-key
DEBUG=False
ALLOWED_HOSTS=xmedical.cloud,www.xmedical.cloud,.xmedical.cloud,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://xmedical.cloud,https://www.xmedical.cloud,https://*.xmedical.cloud,http://xmedical.cloud,http://www.xmedical.cloud
DB_NAME=xmedical
DB_USER=xmedical_user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
TIME_ZONE=America/Tegucigalpa
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# IA (Fase 2) - no guardar claves reales en el repositorio
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:8000
OPENROUTER_APP_NAME=XMedical

# QR (Fase 2)
QR_BASE_URL=http://localhost:8000/qr
QR_EXPIRATION_DAYS=30

# Email / recordatorios (Fase 2)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_FROM=noreply@xmedical.local
SENDGRID_API_KEY=

# Seguridad HTTPS (aplicado cuando DEBUG=False)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_PRELOAD=False
